Content-Type: application/json

{
  "appointmentId": "{{appointmentId}}",
  "patientPhone": "{{patientPhone}}",
  "reason": "Personal emergency — cannot attend the appointment"
}

# ✅ Expect: 200 — body: { message: "Your appointment has been successfully cancelled.", appointmentId, cancelledAt }
# ❌ If you see 409 "within 24 hours": @tomorrowDate is too close — use a date further in the future
# ❌ If you see 404: wrong appointmentId or phone — check @appointmentId and @patientPhone

