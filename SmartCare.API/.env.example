# SmartCare.API — required environment variables (production)
#
# Copy this file to a real .env (which is gitignored) or, preferably, set these
# as real environment variables in your host / container / Vercel / Render etc.
# NOTE: .NET does not auto-load .env files — these must be present as actual
# process environment variables in production. Local development falls back to
# appsettings.Development.json, so you do not need these set locally.

# MongoDB Atlas connection string
MONGODB_CONNECTION_STRING=mongodb+srv://user:password@cluster.mongodb.net/dbname

# JWT signing key — at least 32 chars; generate with: openssl rand -base64 64
JWT_SECRET=generate_with_crypto_randomBytes_64

# Gmail SMTP credentials (App Password, not your account password)
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=your_16_char_app_password

# Allowed browser origin for CORS (your deployed frontend URL)
FRONTEND_URL=https://your-vercel-url.vercel.app

# One-time admin bootstrap secret — random 32+ char string
BOOTSTRAP_SECRET=another_random_32_char_string
